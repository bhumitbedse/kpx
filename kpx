# ── Colors for terminal output ────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[38;5;87m'
ORANGE='\033[38;5;215m'
GREY='\033[38;5;245m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── Print helpers ─────────────────────────────────────────────────────────────
print_error()   { echo -e "${RED}Error: $1${NC}" >&2; }
print_success() { echo -e "${GREEN}✔  $1${NC}"; }
print_info()    { echo -e "${CYAN}ℹ  $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠  $1${NC}"; }

print_banner() {
    local content="kpx  v${VERSION}  theme:${THEME}"
    local box_w=$(( ${#content} + 4 ))  # 2 spaces each side
    local bar; bar=$(printf '%*s' "$box_w" '' | tr ' ' '-')
    local lpad="  "
    local rpad="  "
    printf "${GREY}+%s+${NC}\n" "$bar"
    printf "${GREY}|${NC}%s${ORANGE}${BOLD}kpx${NC}  ${GREY}v${VERSION}  theme:${THEME}${NC}%s${GREY}|${NC}\n" "$lpad" "$rpad"
    printf "${GREY}+%s+${NC}\n" "$bar"
}

# ── Notification ──────────────────────────────────────────────────────────────
send_notify() {
    local title="$1" msg="$2"
    # TC_BG is set by apply_theme — use it as popup background
    local bg_hex="${TC_BG:-#13141f}"

    # Convert hex color to nearest 256-color index for terminal
    # We embed the hex directly as a 24-bit true color escape
    local BOX_BG="\033[48;2;$(printf '%d;%d;%d' "$((16#${bg_hex:1:2}))" "$((16#${bg_hex:3:2}))" "$((16#${bg_hex:5:2}))")m"
    local C_BORDER="\033[38;5;${P_TITLE:-215}m"
    local C_MSG="\033[38;5;${P_USER:-87}m"
    local R="\033[0m"

    {
        local cols rows
        cols=$(tput cols 2>/dev/null || echo 80)
        rows=$(tput lines 2>/dev/null || echo 24)

        local box_w=44
        # Bottom-right corner — last 4 rows, rightmost column
        local col=$(( cols - box_w - 1 ))
        local row=$(( rows - 4 ))
        [ $col -lt 0 ] && col=0
        [ $row -lt 0 ] && row=0

        [ ${#msg} -gt $(( box_w - 6 )) ] && msg="${msg:0:$(( box_w - 6 ))}.."

        local pad=$(( (box_w - 2 - ${#title}) / 2 ))
        local rpad=$(( box_w - 2 - pad - ${#title} ))
        local title_line="│$(printf '%*s' $pad '')${title}$(printf '%*s' $rpad '')│"
        local msg_pad=$(( (box_w - 2 - ${#msg}) / 2 ))
        local msg_rpad=$(( box_w - 2 - msg_pad - ${#msg} ))
        local msg_line="│$(printf '%*s' $msg_pad '')${msg}$(printf '%*s' $msg_rpad '')│"
        local top="╭$(printf '─%.0s' $(seq 1 $((box_w-2))))╮"
        local bot="╰$(printf '─%.0s' $(seq 1 $((box_w-2))))╯"

        tput sc
        tput cup $row $col;       printf "${BOX_BG}${C_BORDER}%s${R}" "$top"
        tput cup $((row+1)) $col; printf "${BOX_BG}${C_BORDER}%s${R}" "$title_line"
        tput cup $((row+2)) $col; printf "${BOX_BG}${C_MSG}%s${R}"    "$msg_line"
        tput cup $((row+3)) $col; printf "${BOX_BG}${C_BORDER}%s${R}" "$bot"
        tput rc

        sleep 2.5

        # Clear with same bg color so it blends perfectly
        local blank="$(printf '%*s' $box_w '')"
        tput sc
        tput cup $row $col;       printf "${BOX_BG}%s${R}" "$blank"
        tput cup $((row+1)) $col; printf "${BOX_BG}%s${R}" "$blank"
        tput cup $((row+2)) $col; printf "${BOX_BG}%s${R}" "$blank"
        tput cup $((row+3)) $col; printf "${BOX_BG}%s${R}" "$blank"
        tput rc
    } >/dev/tty 2>/dev/null &
    disown $! 2>/dev/null || true
}

