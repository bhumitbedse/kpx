#!/usr/bin/env bash

set -euo pipefail

VERSION="1.0.0"
CONFIG_DIR="${HOME}/.config/kpx"
CONFIG_FILE="${CONFIG_DIR}/config"

# ── Global variables ──────────────────────────────────────────────────────────
DATABASE=""
PASSWORD=""
KEYFILE=""
KPPW_FILE="${KPPW_FILE:-}"

# ── Default config values (overridden by config file) ────────────────────────
THEME="tokyo-night"
PASS_TIMEOUT=10
OTHER_TIMEOUT=30
DEFAULT_GROUP="General"

# ── Load config file ──────────────────────────────────────────────────────────
load_config() {
    [ -f "$CONFIG_FILE" ] || return 0
    while IFS='=' read -r key value; do
        [[ "$key" =~ ^#  ]] && continue   # skip comments
        [[ -z "$key"     ]] && continue   # skip blank lines
        key="${key// /}"
        value="${value// /}"
        case "$key" in
            theme)         THEME="$value" ;;
            pass_timeout)  PASS_TIMEOUT="$value" ;;
            other_timeout) OTHER_TIMEOUT="$value" ;;
            default_group) DEFAULT_GROUP="$value" ;;
        esac
    done < "$CONFIG_FILE"
}

# ── Create default config + example if missing ───────────────────────────────
init_config() {
    mkdir -p "$CONFIG_DIR"
    if [ ! -f "$CONFIG_FILE" ]; then
        cat > "$CONFIG_FILE" << 'EOF'
# kpx configuration
# ─────────────────────────────────────────────────────
# Theme options: tokyo-night | gruvbox | catppuccin | dracula | nord | minimal
theme = tokyo-night

# Clipboard clear timeouts (seconds)
pass_timeout  = 10
other_timeout = 30

# Default group when adding new entries
default_group = General

# Databases — add one per line:
# database = /home/user/passwords.kdbx
# database = /home/user/work.kdbx
# keyfile  = /home/user/my.key    (optional, paired with last database line)
EOF
        echo "Created default config at $CONFIG_FILE"
    fi
}

# ── Read databases from config ────────────────────────────────────────────────
get_config_databases() {
    [ -f "$CONFIG_FILE" ] || return
    local last_db=""
    while IFS='=' read -r key value; do
        [[ "$key" =~ ^# ]] && continue
        [[ -z "$key"    ]] && continue
        key="${key// /}"; value="${value// /}"
        case "$key" in
            database) echo "db:$value" ;;
            keyfile)  echo "kf:$value" ;;
        esac
    done < "$CONFIG_FILE"
}

